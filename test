<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ascent Hospitality Management — Rooted & Rising</title>

<!-- Typography: Freight Display Pro feel via Playfair Display + refined sans via DM Sans -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════════════════
   DESIGN TOKENS
   ═══════════════════════════════════════════════════════ */
:root {
  /* Palette — warm, grounded, premium */
  --black: #131110;
  --charcoal: #1c1917;
  --dark: #292524;
  --stone: #44403c;
  --warm-gray: #78716c;
  --sand: #a8a29e;
  --cream: #f5f0ea;
  --ivory: #faf8f5;
  --white: #fffdf9;
  --copper: #c2855a;
  --copper-light: #d4a574;
  --forest: #2d4a3e;
  --forest-light: #3d6b5a;

  /* Type scale — editorial, generous */
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body: 'DM Sans', -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;

  /* Spacing — 8px base grid */
  --space-xs: 0.5rem;
  --space-sm: 1rem;
  --space-md: 2rem;
  --space-lg: 4rem;
  --space-xl: 6rem;
  --space-2xl: 8rem;
  --space-3xl: 12rem;

  /* Layout */
  --max-width: 1440px;
  --gutter: clamp(1.5rem, 4vw, 4rem);
  --column: calc((100% - var(--gutter) * 11) / 12);
}

/* ═══════════════════════════════════════════════════════
   RESET + BASE
   ═══════════════════════════════════════════════════════ */
*, *::before, *::after {
  margin: 0; padding: 0; box-sizing: border-box;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-body);
  font-weight: 400;
  color: var(--charcoal);
  background: var(--white);
  line-height: 1.6;
  overflow-x: hidden;
}

img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }

/* ═══════════════════════════════════════════════════════
   UTILITY
   ═══════════════════════════════════════════════════════ */
.container {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 var(--gutter);
}

.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--copper);
}

.section-pad {
  padding: var(--space-3xl) 0;
}

/* ═══════════════════════════════════════════════════════
   NAVIGATION
   ═══════════════════════════════════════════════════════ */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 1.5rem var(--gutter);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.4s ease, padding 0.4s ease;
}

.nav.scrolled {
  background: rgba(19, 17, 16, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 1rem var(--gutter);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.nav-logo svg {
  width: 32px;
  height: 32px;
}

.nav-wordmark {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--white);
}

.nav-links {
  display: flex;
  gap: 2.5rem;
  list-style: none;
}

.nav-links a {
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255, 253, 249, 0.7);
  transition: color 0.3s ease;
}

.nav-links a:hover {
  color: var(--copper-light);
}

.nav-cta {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--white) !important;
  border: 1px solid rgba(255,253,249,0.3);
  padding: 0.6rem 1.5rem;
  transition: all 0.3s ease;
}

.nav-cta:hover {
  background: var(--copper);
  border-color: var(--copper);
}

/* ═══════════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════════ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 var(--gutter) var(--space-xl);
  background: var(--black);
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  /* Warm, cinematic gradient simulating a diner interior at golden hour */
  background:
    linear-gradient(180deg,
      rgba(19,17,16,0.3) 0%,
      rgba(19,17,16,0.1) 40%,
      rgba(19,17,16,0.7) 80%,
      rgba(19,17,16,0.95) 100%
    ),
    linear-gradient(135deg,
      #3d2b1f 0%,
      #5c3d2e 25%,
      #2d4a3e 50%,
      #1c1917 75%,
      #131110 100%
    );
}

/* Simulated photography overlay — warm grain */
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
  background-size: 256px;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: var(--max-width);
  margin: 0 auto;
  width: 100%;
}

.hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 300;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--copper-light);
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeUp 0.8s ease 0.4s forwards;
}

.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 6.5rem);
  font-weight: 400;
  line-height: 1.05;
  color: var(--white);
  max-width: 14ch;
  letter-spacing: -0.02em;
  opacity: 0;
  animation: fadeUp 1s ease 0.6s forwards;
}

.hero h1 em {
  font-style: italic;
  color: var(--copper-light);
}

.hero-sub {
  font-family: var(--font-body);
  font-size: 1.15rem;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255,253,249,0.6);
  max-width: 42ch;
  margin-top: 2rem;
  opacity: 0;
  animation: fadeUp 0.8s ease 0.9s forwards;
}

.hero-scroll-indicator {
  position: absolute;
  bottom: 2rem;
  right: var(--gutter);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  opacity: 0;
  animation: fadeUp 0.8s ease 1.2s forwards;
}

.hero-scroll-indicator span {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,253,249,0.35);
  writing-mode: vertical-rl;
}

.scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--copper-light), transparent);
  animation: scrollPulse 2s ease infinite;
}

/* ═══════════════════════════════════════════════════════
   BRAND STATEMENT
   ═══════════════════════════════════════════════════════ */
.brand-statement {
  padding: var(--space-3xl) var(--gutter);
  background: var(--white);
}

.brand-statement-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
  align-items: start;
}

.brand-statement-left {
  padding-top: 0.5rem;
}

.brand-statement h2 {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 3.5vw, 3.5rem);
  font-weight: 400;
  line-height: 1.2;
  color: var(--charcoal);
  letter-spacing: -0.01em;
}

.brand-statement h2 em {
  font-style: italic;
  color: var(--copper);
}

.brand-statement-right {
  padding-top: 1rem;
}

.brand-statement-right p {
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 300;
  line-height: 1.85;
  color: var(--stone);
  max-width: 48ch;
}

.brand-statement-right p + p {
  margin-top: 1.5rem;
}

.divider {
  display: block;
  width: 48px;
  height: 1px;
  background: var(--copper);
  margin: 2rem 0;
}

/* ═══════════════════════════════════════════════════════
   OUR BRANDS
   ═══════════════════════════════════════════════════════ */
.brands {
  background: var(--charcoal);
  padding: var(--space-3xl) 0;
  overflow: hidden;
}

.brands-header {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 var(--gutter);
  margin-bottom: var(--space-xl);
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.brands-header h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3vw, 3rem);
  font-weight: 400;
  color: var(--white);
  line-height: 1.15;
}

.brands-header p {
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: rgba(255,253,249,0.5);
  max-width: 32ch;
  text-align: right;
  line-height: 1.6;
}

.brand-cards {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 var(--gutter);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}

.brand-card {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  aspect-ratio: 4/3;
  cursor: pointer;
  group: true;
}

.brand-card-bg {
  position: absolute;
  inset: 0;
  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.brand-card:hover .brand-card-bg {
  transform: scale(1.04);
}

/* Perkins — warm greens and baked warmth */
.brand-card--perkins .brand-card-bg {
  background:
    linear-gradient(160deg,
      rgba(45,74,62,0.9) 0%,
      rgba(61,107,90,0.85) 40%,
      rgba(92,61,46,0.7) 100%
    ),
    linear-gradient(to bottom right, #2d4a3e, #5c3d2e);
}

/* Huddle House — warm amber, diner energy */
.brand-card--huddle .brand-card-bg {
  background:
    linear-gradient(160deg,
      rgba(194,133,90,0.85) 0%,
      rgba(156,98,60,0.8) 40%,
      rgba(44,40,36,0.9) 100%
    ),
    linear-gradient(to bottom right, #c2855a, #2c2824);
}

.brand-card-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 2.5rem;
}

.brand-card-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,253,249,0.5);
}

.brand-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.brand-card h3 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 400;
  color: var(--white);
  line-height: 1.1;
}

.brand-card-tagline {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 300;
  color: rgba(255,253,249,0.6);
  margin-top: 0.5rem;
  max-width: 28ch;
}

.brand-card-arrow {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1px solid rgba(255,253,249,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.brand-card:hover .brand-card-arrow {
  background: var(--white);
  border-color: var(--white);
}

.brand-card:hover .brand-card-arrow svg path {
  stroke: var(--charcoal);
}

.brand-card-arrow svg {
  width: 18px;
  height: 18px;
}

.brand-card-arrow svg path {
  stroke: rgba(255,253,249,0.6);
  transition: stroke 0.3s ease;
}

/* ═══════════════════════════════════════════════════════
   FRANCHISE / WHY ASCENT
   ═══════════════════════════════════════════════════════ */
.franchise {
  padding: var(--space-3xl) var(--gutter);
  background: var(--ivory);
}

.franchise-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}

.franchise-top {
  display: grid;
  grid-template-columns: 5fr 7fr;
  gap: var(--space-xl);
  align-items: start;
  margin-bottom: var(--space-xl);
}

.franchise h2 {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 3.5vw, 3.5rem);
  font-weight: 400;
  line-height: 1.15;
  color: var(--charcoal);
}

.franchise-intro {
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 300;
  line-height: 1.85;
  color: var(--stone);
  max-width: 52ch;
  padding-top: 1rem;
}

.franchise-pillars {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-top: var(--space-lg);
}

.pillar {
  padding: 2.5rem;
  background: var(--white);
  border-radius: 8px;
  border: 1px solid rgba(0,0,0,0.04);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.pillar:hover {
  transform: translateY(-4px);
  box-shadow: 0 24px 48px rgba(0,0,0,0.06);
}

.pillar-number {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  color: var(--copper);
  margin-bottom: 1.5rem;
}

.pillar h3 {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 500;
  color: var(--charcoal);
  margin-bottom: 1rem;
  line-height: 1.25;
}

.pillar p {
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 300;
  line-height: 1.75;
  color: var(--warm-gray);
}

/* ═══════════════════════════════════════════════════════
   SCALE / PROOF — EDITORIAL NUMBER MOMENT
   ═══════════════════════════════════════════════════════ */
.scale {
  padding: var(--space-3xl) var(--gutter);
  background: var(--black);
  position: relative;
  overflow: hidden;
}

.scale::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 60%;
  height: 140%;
  background: radial-gradient(ellipse, rgba(194,133,90,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.scale-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  position: relative;
  z-index: 2;
}

.scale-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: var(--space-xl);
  border-bottom: 1px solid rgba(255,253,249,0.08);
  padding-bottom: var(--space-md);
}

.scale-top h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3vw, 2.5rem);
  font-weight: 400;
  color: var(--white);
}

.scale-top p {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: rgba(255,253,249,0.4);
  max-width: 36ch;
  text-align: right;
  line-height: 1.6;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}

.stat {
  padding: var(--space-lg) 0;
  border-right: 1px solid rgba(255,253,249,0.06);
  padding-right: 2rem;
}

.stat:last-child {
  border-right: none;
}

.stat:not(:first-child) {
  padding-left: 2rem;
}

.stat-number {
  font-family: var(--font-display);
  font-size: clamp(3rem, 5vw, 4.5rem);
  font-weight: 400;
  color: var(--copper-light);
  line-height: 1;
  margin-bottom: 0.75rem;
  letter-spacing: -0.02em;
}

.stat-label {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 400;
  color: rgba(255,253,249,0.5);
  line-height: 1.5;
}

.stat-detail {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,253,249,0.25);
  margin-top: 0.75rem;
}

/* ═══════════════════════════════════════════════════════
   PEOPLE / CULTURE — EDITORIAL SPLIT
   ═══════════════════════════════════════════════════════ */
.culture {
  padding: var(--space-3xl) var(--gutter);
  background: var(--white);
}

.culture-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 7fr 5fr;
  gap: var(--space-xl);
  align-items: center;
}

.culture-image {
  aspect-ratio: 4/5;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  /* Warm photographic placeholder */
  background:
    linear-gradient(170deg,
      rgba(194,133,90,0.15) 0%,
      rgba(45,74,62,0.12) 50%,
      rgba(28,25,23,0.08) 100%
    ),
    var(--cream);
}

.culture-image-label {
  position: absolute;
  bottom: 1.5rem;
  left: 1.5rem;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--warm-gray);
  background: rgba(255,253,249,0.85);
  backdrop-filter: blur(8px);
  padding: 0.4rem 0.8rem;
  border-radius: 3px;
}

.culture-text {
  padding-left: var(--space-lg);
}

.culture-text h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3vw, 3rem);
  font-weight: 400;
  line-height: 1.2;
  color: var(--charcoal);
  margin-bottom: 2rem;
}

.culture-text h2 em {
  font-style: italic;
  color: var(--copper);
}

.culture-text p {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 300;
  line-height: 1.85;
  color: var(--stone);
  max-width: 40ch;
}

.culture-text p + p {
  margin-top: 1.25rem;
}

.culture-values {
  display: flex;
  gap: 2rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(0,0,0,0.06);
}

.value-item {
  flex: 1;
}

.value-item h4 {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--charcoal);
  margin-bottom: 0.5rem;
}

.value-item p {
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 300;
  line-height: 1.6;
  color: var(--warm-gray);
}

/* ═══════════════════════════════════════════════════════
   QUOTE / LEADERSHIP PULL
   ═══════════════════════════════════════════════════════ */
.quote-section {
  padding: var(--space-3xl) var(--gutter);
  background: var(--ivory);
  text-align: center;
}

.quote-section-inner {
  max-width: 720px;
  margin: 0 auto;
}

.quote-mark {
  font-family: var(--font-display);
  font-size: 4rem;
  color: var(--copper);
  line-height: 1;
  margin-bottom: 1rem;
}

.quote-text {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  font-weight: 400;
  font-style: italic;
  line-height: 1.45;
  color: var(--charcoal);
  margin-bottom: 2rem;
}

.quote-attribution {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--stone);
}

.quote-attribution strong {
  font-weight: 500;
  color: var(--charcoal);
}

/* ═══════════════════════════════════════════════════════
   FINAL CTA
   ═══════════════════════════════════════════════════════ */
.final-cta {
  padding: var(--space-3xl) var(--gutter);
  background: var(--charcoal);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.final-cta::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  height: 80%;
  background: radial-gradient(ellipse, rgba(194,133,90,0.04) 0%, transparent 70%);
  pointer-events: none;
