    const u = () => {
      const raw = i.value.trim();
      const v = t ? t(raw) : raw;
      o.textContent = v;
      o.setAttribute('data-empty', v==='');
    };
    i.addEventListener('input', u); u();
  });

  // Track which headline + script word belong to each layout so they don't trample each other
  const layoutTitles  = { hero: "Today's", multi: 'Daily',    drinks: 'Specialty', drinksPhoto: 'Featured' };
  const layoutScripts = { hero: 'Special', multi: 'Specials', drinks: 'Drinks',    drinksPhoto: 'Drinks' };
  const titleInput  = document.getElementById('f-title');
  const scriptInput = document.getElementById('f-script');
  titleInput.addEventListener('input',  () => { layoutTitles[state.layout]  = titleInput.value; });
  scriptInput.addEventListener('input', () => { layoutScripts[state.layout] = scriptInput.value; });

  function setLayout(m) {
    // Remember the current input values for the layout we're leaving
    layoutTitles[state.layout]  = titleInput.value;
    layoutScripts[state.layout] = scriptInput.value;
    state.layout = m;
    tHero.classList.toggle('on',         m==='hero');
    tMulti.classList.toggle('on',        m==='multi');
    tDrinks.classList.toggle('on',       m==='drinks');
    tDrinksPhoto.classList.toggle('on',  m==='drinksPhoto');
    heroFields.style.display        = m==='hero'        ? '' : 'none';
    multiFields.style.display       = m==='multi'       ? '' : 'none';
    drinksFields.style.display      = m==='drinks'      ? '' : 'none';
    drinksPhotoFields.style.display = m==='drinksPhoto' ? '' : 'none';
    heroView.style.display        = m==='hero'        ? '' : 'none';
    multiView.style.display       = m==='multi'       ? '' : 'none';
    drinksPhotoView.style.display = m==='drinksPhoto' ? '' : 'none';
    // drinksView visibility + menu-mode class depend on the drink-style sub-toggle
    if (m === 'drinks') {
      drinksView.style.display = state.drinkStyle === 'simple' ? '' : 'none';
      card.classList.toggle('menu-mode', state.drinkStyle !== 'simple');
      if (state.drinkStyle !== 'simple') card.setAttribute('data-drinkstyle', state.drinkStyle);
      else card.removeAttribute('data-drinkstyle');
    } else {
      drinksView.style.display = 'none';
      card.classList.remove('menu-mode');
      card.removeAttribute('data-drinkstyle');
    }
    // Swap headline + script word to the layout-appropriate values
    titleInput.value  = layoutTitles[m];
    scriptInput.value = layoutScripts[m];
    titleInput.dispatchEvent(new Event('input'));
    scriptInput.dispatchEvent(new Event('input'));
    if (m==='multi')       renderMulti();
    if (m==='drinks')      { renderDrinks(); if (state.drinkStyle !== 'simple') drawMenu(); }
    if (m==='drinksPhoto') renderDrinksPhoto();
  }

  function renderMulti() {
    const list = document.getElementById('multiList');
    list.innerHTML = '';
    state.specials.forEach((s, i) => {
      const b = document.createElement('div');
      b.className = 'special';
      b.innerHTML = `
        <div class="special-head">
          <span>Special ${i+1}</span>
          ${state.specials.length>1 ? `<button onclick="removeSpecial(${i})">✕</button>` : ''}
        </div>
        <label>Name</label><input data-i="${i}" data-k="name" value="${esc(s.name)}" maxlength="40"/>
        <label>Description</label><textarea data-i="${i}" data-k="desc" maxlength="120">${esc(s.desc)}</textarea>
        <label>Price</label><input data-i="${i}" data-k="price" value="${esc(s.price)}" maxlength="10"/>`;
      list.appendChild(b);
    });
    list.querySelectorAll('input,textarea').forEach(el => {
      el.addEventListener('input', () => {
        state.specials[+el.dataset.i][el.dataset.k] = el.value;
        drawMulti();
      });
    });
    addBtn.disabled = state.specials.length >= 7;
    drawMulti();
  }

  function drawMulti() {
    multiView.innerHTML = state.specials.map(s => `
      <div class="item">
        <h4 class="n">${esc(s.name)}</h4>
        <div class="p">${esc(stripDollar(s.price))}</div>
        ${s.desc.trim() ? `<p class="d">${esc(s.desc)}</p>` : ''}
      </div>`).join('');
  }

  function addSpecial() { if (state.specials.length<7) { state.specials.push({name:'New special',desc:'',price:'$0'}); renderMulti(); } }
  function removeSpecial(i) { state.specials.splice(i,1); renderMulti(); }

  // ---------- DRINK MENU style (alternate layouts inside Drink list) ----------
  state.drinkStyle = 'simple'; // 'simple' | 'light' | 'dark'

  function setDrinkStyle(s) {
    state.drinkStyle = s;
    dsSimple.classList.toggle('on', s==='simple');
    dsLight.classList.toggle('on',  s==='light');
    dsDark.classList.toggle('on',   s==='dark');
    // Toggle which sub-view is visible inside the Drink list mode
    if (state.layout === 'drinks') {
      drinksView.style.display = s==='simple' ? '' : 'none';
      card.classList.toggle('menu-mode', s !== 'simple');
      if (s === 'simple') {
        card.removeAttribute('data-drinkstyle');
        drawDrinks();
      } else {
        card.setAttribute('data-drinkstyle', s);
        drawMenu();
      }
    }
  }

  function drawMenu() {
    // Group drinks by category, preserving first-seen order
    const groups = new Map();
    state.drinks.forEach(d => {
      const k = (d.cat || 'Other').trim() || 'Other';
      if (!groups.has(k)) groups.set(k, []);
      groups.get(k).push(d);
    });
    const entries = [...groups.entries()];

    const renderSection = ([cat, items]) => `
      <div class="menu-section">
        <h3>${esc(cat)}</h3>
        ${items.map(d => `
          <div class="mitem">
            <div class="row">
              <h4 class="n">${esc(d.name)}</h4>
              <div class="p">${esc(stripDollar(d.price))}</div>
            </div>
            ${d.desc && d.desc.trim() ? `<p class="d">${esc(d.desc)}</p>` : ''}
          </div>`).join('')}
      </div>`;

    // Match the source layout: first category goes in left column, the rest stack in right.
    // Special case: with a single category, render it across both columns by item count.
    const colL = document.getElementById('menuColL');
    const colR = document.getElementById('menuColR');
    if (entries.length === 1) {
      const [cat, items] = entries[0];
      const half = Math.ceil(items.length / 2);
      colL.innerHTML = renderSection([cat, items.slice(0, half)]);
      colR.innerHTML = renderSection(['', items.slice(half)]).replace(/<h3>\s*<\/h3>/, '');
    } else {
      colL.innerHTML = renderSection(entries[0]);
      colR.innerHTML = entries.slice(1).map(renderSection).join('');
    }
  }

  function renderDrinks() {
    const list = document.getElementById('drinksList');
    list.innerHTML = '';
    state.drinks.forEach((d, i) => {
      const b = document.createElement('div');
      b.className = 'special';
      b.innerHTML = `
        <div class="special-head">
          <span>Drink ${i+1}</span>
          ${state.drinks.length>1 ? `<button onclick="removeDrink(${i})">✕</button>` : ''}
        </div>
        <label>Category (e.g. Cocktail / Wine / Beer)</label><input data-i="${i}" data-k="cat"   value="${esc(d.cat)}" maxlength="16"/>
        <label>Name</label>                                    <input data-i="${i}" data-k="name"  value="${esc(d.name)}" maxlength="40"/>
        <label>Description</label>                          <textarea data-i="${i}" data-k="desc"  maxlength="120">${esc(d.desc)}</textarea>
        <label>Price</label>                                   <input data-i="${i}" data-k="price" value="${esc(d.price)}" maxlength="10"/>`;
      list.appendChild(b);
    });
    list.querySelectorAll('input,textarea').forEach(el => {
      el.addEventListener('input', () => {
        state.drinks[+el.dataset.i][el.dataset.k] = el.value;
        drawDrinks();
        if (state.drinkStyle !== 'simple') drawMenu();
      });
    });
    addDrinkBtn.disabled = state.drinks.length >= 12;
    drawDrinks();
    if (state.drinkStyle !== 'simple') drawMenu();
  }

  function drawDrinks() {
    drinksView.innerHTML = state.drinks.map(d => `
      <div class="item">
        <h4 class="n">${d.cat.trim() ? `<span class="cat">${esc(d.cat)}</span>` : ''}${esc(d.name)}</h4>
        <div class="p">${esc(stripDollar(d.price))}</div>
        ${d.desc.trim() ? `<p class="d">${esc(d.desc)}</p>` : ''}
      </div>`).join('');
  }

  function addDrink() {
    if (state.drinks.length<12) {
      state.drinks.push({cat:'',name:'New drink',desc:'',price:'$0'});
      renderDrinks();
      if (state.drinkStyle !== 'simple') drawMenu();
    }
  }
  function removeDrink(i) {
    state.drinks.splice(i,1);
    renderDrinks();
    if (state.drinkStyle !== 'simple') drawMenu();
  }

  // ---------- DRINKS WITH PHOTOS (2x2 grid) ----------
  let pickingForIndex = null; // which tile is currently picking a photo

  function renderDrinksPhoto() {
    const list = document.getElementById('drinksPhotoList');
    list.innerHTML = '';
    state.drinksPhoto.forEach((d, i) => {
      const photo = photoById(d.photoId);
      const thumb = photo ? `<div class="photo-thumb" onclick="openLib(${i})" style="background-image:url('${photo.src}')"></div>`
                          : `<div class="photo-thumb" onclick="openLib(${i})">+</div>`;
      const b = document.createElement('div');
      b.className = 'special';
      b.innerHTML = `
        <div class="special-head">
          <span>Drink ${i+1}</span>
          ${state.drinksPhoto.length>1 ? `<button onclick="removeDrinkPhoto(${i})">✕</button>` : ''}
        </div>
        <div class="photo-pick">
          ${thumb}
          <div>
            <label style="margin-top:0">Category</label><input data-i="${i}" data-k="cat"   value="${esc(d.cat)}"   maxlength="16"/>
          </div>
        </div>
        <label>Name</label>        <input    data-i="${i}" data-k="name"  value="${esc(d.name)}"  maxlength="40"/>
        <label>Description</label> <textarea data-i="${i}" data-k="desc"  maxlength="80">${esc(d.desc)}</textarea>
        <label>Price</label>       <input    data-i="${i}" data-k="price" value="${esc(d.price)}" maxlength="10"/>`;
      list.appendChild(b);
    });
    list.querySelectorAll('input,textarea').forEach(el => {
      el.addEventListener('input', () => {
        state.drinksPhoto[+el.dataset.i][el.dataset.k] = el.value;
        drawDrinksPhoto();
      });
    });
    addDrinkPhotoBtn.disabled = state.drinksPhoto.length >= 4;
    drawDrinksPhoto();
  }

  function drawDrinksPhoto() {
    drinksPhotoView.setAttribute('data-count', state.drinksPhoto.length);
    drinksPhotoView.innerHTML = state.drinksPhoto.map(d => {
      const photo = photoById(d.photoId);
      const img = photo ? `<div class="img" style="background-image:url('${photo.src}')"></div>` : `<div class="img"></div>`;
      return `
        <div class="photo-tile">
          ${img}
          ${d.cat.trim() ? `<div class="cat">${esc(d.cat)}</div>` : ''}
          <div class="row">
            <h4 class="n">${esc(d.name)}</h4>
            <div class="p">${esc(stripDollar(d.price))}</div>
          </div>
          ${d.desc.trim() ? `<p class="d">${esc(d.desc)}</p>` : ''}
        </div>`;
    }).join('');
  }

  function addDrinkPhoto() {
    if (state.drinksPhoto.length >= 4) return;
    state.drinksPhoto.push({ photoId: null, cat: '', name: 'New drink', desc: '', price: '0' });
    renderDrinksPhoto();
  }
  function removeDrinkPhoto(i) {
    if (state.drinksPhoto.length <= 1) return;
    state.drinksPhoto.splice(i, 1);
    renderDrinksPhoto();
  }

  // ---------- PHOTO LIBRARY PICKER ----------
  function openLib(idx) {
    pickingForIndex = idx;
    const grid = document.getElementById('libGrid');
    grid.innerHTML = PHOTO_LIBRARY.map(p => `
      <div class="lib-tile" onclick="selectPhoto('${p.id}')">
        <div class="lib-img" style="background-image:url('${p.src}'); background-size:cover; background-position:center"></div>
        <div class="lib-name">${esc(p.name)}</div>
      </div>`).join('');
    libOverlay.classList.add('open');
  }
  function closeLib() {
    libOverlay.classList.remove('open');
    pickingForIndex = null;
  }
  function selectPhoto(id) {
    if (pickingForIndex == null) return closeLib();
    state.drinksPhoto[pickingForIndex].photoId = id;
    renderDrinksPhoto();
    closeLib();
  }
  function esc(s) { return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

  // ---------- PAGE SIZE ----------
  // Native pixel dimensions @ 96 dpi for each print size
  const PAGE_SIZES = {
    letter: { w: 816, h: 1056, inches: '8.5in 11in', label: '8.5 × 11 in' },
    half:   { w: 528, h: 816,  inches: '5.5in 8.5in', label: '5.5 × 8.5 in' },
  };
  const pageStyle = document.getElementById('pageStyle');
  const sLetter = document.getElementById('sLetter');
  const sHalf   = document.getElementById('sHalf');
  const sizeLabel = document.getElementById('sizeLabel');
  let pageSize = 'letter';

  function setPageSize(size) {
    pageSize = size;
    sLetter.classList.toggle('on', size==='letter');
    sHalf.classList.toggle('on',   size==='half');
    card.setAttribute('data-size', size);
    sizeLabel.textContent = PAGE_SIZES[size].label;
    // Update the @page rule for print
    pageStyle.textContent = `@page { size: ${PAGE_SIZES[size].inches}; margin: 0; }`;
    fitCard();
  }

  // ---------- PNG EXPORT ----------
  async function downloadPNG() {
    const { w, h } = PAGE_SIZES[pageSize];
    const prevTransform = card.style.transform;
    card.style.transform = 'none';
    try {
      const canvas = await html2canvas(card, { scale: 3, backgroundColor: null, logging: false, width: w, height: h });
      const link = document.createElement('a');
      link.download = `perkins-specials-${pageSize}-${new Date().toISOString().slice(0,10)}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    } finally {
      card.style.transform = prevTransform;
    }
  }

  // ---------- PRINT ----------
  window.addEventListener('beforeprint', () => {
    printable.innerHTML = '';
    const clone = card.cloneNode(true);
    clone.style.transform = 'none';
    const { inches } = PAGE_SIZES[pageSize];
    const [iw, ih] = inches.split(' ');
    clone.style.width = iw;
    clone.style.height = ih;
    printable.appendChild(clone);
  });
  window.addEventListener('afterprint', () => { printable.innerHTML = ''; });

  // ---------- MENU FOOTER LOGO ----------
  // Clone both Perkins lockups (green + white) into the menu footer; CSS swaps
  // between them based on the dark/light drinkstyle.
  // Crop the viewBox so only the script wordmark renders (the menu design uses
  // just the "Perkins" mark, not the full "Restaurant & Bakery" lockup).
  const WORDMARK_VIEWBOX = '0 0 1728 720'; // full lockup is 1728x936; trim the R&B subtitle
  (function setupMenuFootLogo(){
    const foot = document.getElementById('menuFoot');
    if (!foot) return;
    const green = document.getElementById('perkinsLogoSvg');
    const white = document.getElementById('perkinsLogoWhiteSvg');
    if (green) {
      const g = green.cloneNode(true);
      g.removeAttribute('id');
      g.classList.add('logo-img', 'logo-green');
      g.setAttribute('viewBox', WORDMARK_VIEWBOX);
      foot.appendChild(g);
    }
    if (white) {
      const w = white.cloneNode(true);
      w.removeAttribute('id');
      w.removeAttribute('style'); // remove the display:none from the original
      w.classList.add('logo-img', 'logo-white');
      w.setAttribute('viewBox', WORDMARK_VIEWBOX);
      foot.appendChild(w);
    }
  })();

  // ---------- RESPONSIVE CARD SCALING ----------
  const cardFrame = document.getElementById('cardFrame');
  const stage = document.querySelector('.stage');
  function fitCard() {
    const { w, h } = PAGE_SIZES[pageSize];
    const available = stage.clientWidth - 24;
    const scale = Math.min(1, available / w);
    card.style.transform = `scale(${scale})`;
    cardFrame.style.width  = `${w * scale}px`;
    cardFrame.style.height = `${h * scale}px`;
  }
  fitCard();
  window.addEventListener('resize', fitCard);
  // Refit when fonts finish loading (Lobster may shift metrics)
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(fitCard);
</script>
</body>
</html>
